# Copy to .env and fill in.

# Required for the AI-judge strategy ("ai" ledger). Without it the bot runs
# math-only.
ANTHROPIC_API_KEY=

# Only needed for --live trading (real orders on the Polymarket CLOB).
# Export the private key of the wallet that holds your USDC on Polygon.
POLYMARKET_PRIVATE_KEY=
# If you trade through a Polymarket proxy wallet (email/Magic login), set the
# proxy address here; leave empty for a plain EOA wallet.
POLYMARKET_FUNDER_ADDRESS=
