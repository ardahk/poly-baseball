# Copy to .env and fill in.

# Required for the AI-judge strategy ("ai" ledger). Without it the bot runs
# math-only.
ANTHROPIC_API_KEY=

# Only needed for --live trading (real orders on the Polymarket CLOB).
#
# IMPORTANT: this is your WALLET PRIVATE KEY (the 0x... hex string you export
# from your wallet / from Polymarket's "Export Private Key"), NOT the CLOB
# "API key" shown in the developer settings. The API key/secret/passphrase are
# derived automatically from this private key at startup. If you paste an API
# key here, order signing will fail. No quotes needed.
POLYMARKET_PRIVATE_KEY=
#
# If you funded via Polymarket's website (email / Magic login), your USDC sits
# in a proxy wallet — set its address here (find it as your deposit address on
# Polymarket). Leave empty only if you use a plain self-custody wallet whose
# private key above directly holds the USDC.
POLYMARKET_FUNDER_ADDRESS=
