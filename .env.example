# Copy to .env and fill in.

# Required for the AI-judge strategy ("ai" ledger). Without it the bot runs
# math-only.
ANTHROPIC_API_KEY=

# Only needed for --live trading (real orders on Polymarket US).
#
# These are the API credentials from polymarket.us/developer. The secret key
# should be pasted exactly as issued, with no surrounding quotes.
POLYMARKET_KEY_ID=
POLYMARKET_SECRET_KEY=

# Optional: set to "yes" only for unattended live-mode services.
# Without this, `python main.py run --live` asks for interactive confirmation.
POLYBOT_CONFIRM_LIVE=
